{
  "name": "agent-skills",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Authoring, validation, and release tooling for a curated multi-runtime Agent Skills library.",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "acta": "node scripts/materialize-acta.mjs",
    "acta:check": "node scripts/materialize-acta.mjs --check",
    "acta2": "node scripts/materialize-acta2.mjs",
    "acta2:check": "node scripts/materialize-acta2.mjs --check",
    "catalog": "node scripts/generate-catalog.mjs",
    "catalog:check": "node scripts/generate-catalog.mjs --check",
    "check": "node scripts/check.mjs",
    "new:skill": "node scripts/new-skill.mjs",
    "qa:prepare": "node scripts/prepare-manual-qa.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "test": "node --test \"tests/*.test.mjs\"",
    "test:install": "node scripts/install-smoke.mjs",
    "typecheck": "tsc -p jsconfig.json",
    "validate": "node scripts/validate.mjs",
    "validate:acta": "node scripts/validate-acta.mjs",
    "validate:acta2": "node scripts/validate-acta2.mjs",
    "validate:repository": "node scripts/validate-repository.mjs"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "acorn": "8.17.0",
    "parse5": "8.0.1",
    "skills": "1.5.19",
    "typescript": "7.0.2",
    "yaml": "2.9.0"
  }
}
